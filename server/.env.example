# Copy to server/.env and fill in. Never commit the real .env.
#
# Two ways to run the database:
#   A) MANAGED (recommended, reachable anywhere) — Neon / Render / Supabase.
#      Set ONLY DATABASE_URL below. `npm run db:setup` applies the schema.
#   B) SELF-HOSTED — your own/local Postgres. Also set the PG_SUPERUSER_URL +
#      APP_DB_PASSWORD block at the bottom so setup can create the role + db.

# ---- (A) Managed Postgres: paste the connection string from your provider ----
# Neon gives you something like this (keep ?sslmode=require — TLS is enforced):
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/shopops?sslmode=require

# Secret used to sign login tokens (any long random string)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# API/web port (Render/most hosts set this automatically; default 4000 locally)
PORT=4000

# ---- (B) Self-hosted ONLY — used once by `npm run db:setup` ----
# Leave these unset when using managed Postgres (A).
# Superuser connection to create the shopops role + database.
# PG_SUPERUSER_URL=postgresql://postgres:CHANGE_ME_POSTGRES_PASSWORD@localhost:5432/postgres
# Password the app role (shopops) will be created with — must match DATABASE_URL above.
# APP_DB_PASSWORD=CHANGE_ME_APP_PASSWORD

# ---- Used once by `npm run db:seed` ----
SEED_OWNER_USERNAME=owner
SEED_OWNER_PASSWORD=CHANGE_ME_OWNER_PASSWORD
SEED_OWNER_NAME=Shop Owner
SEED_SHOP_NAME=My Electronics Shop
SEED_BRANCH_NAME=Branch 1
# Demo logins (manager1/sales1/tech1/partner1). Set SEED_DEMO_USERS=false to skip.
SEED_DEMO_PASSWORD=changeme123
